# E2E test environment — template. Copy to `.env.test` and fill with real values.
# `.env.test` is gitignored: never commit real secrets.
# In CI, these are injected from GitHub Actions secrets (see .github/workflows/ci.yml).

# Test target + fixtures
TEST_BASE_URL=http://localhost:3000
TEST_EMAIL=test@example.com
TEST_PHONE=+447000000000
TEST_PASSWORD=replace-me

# Stripe test card fixtures (Stripe-published test values, not secrets)
STRIPE_TEST_CARD=4242424242424242
STRIPE_DECLINED_CARD=4000000000000002
STRIPE_EXPIRY=12/34
STRIPE_CVC=123
STRIPE_ZIP=SW1A1AA

# Supabase — use a dedicated TEST project, never production keys
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
