# ── Frontend (Vite — must be prefixed VITE_ to be exposed to the browser) ────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sentry (frontend error monitoring) ───────────────────────────────────────
# Get your DSN from sentry.io → Settings → Projects → Client Keys
VITE_SENTRY_DSN=https://your-dsn@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Demo audio generation (server-side / build-time ONLY — never VITE_ prefix) ─
# Run once: GEMINI_API_KEY=<key> npm run generate:demo-audio
# Then commit the generated public/assets/generated/sample-call.wav
# The key is NOT bundled into the frontend. Do not add a VITE_ version.
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Backend (Railway) ────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:3000,https://tradereceptionist.com

# ── Supabase (server-side only — service-role key bypasses RLS) ───────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Retell AI ─────────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=https://trade-receptionist-production.up.railway.app/webhooks/retell
# Full public URL that Retell will POST call events to, e.g.:
# https://trade-receptionist-production.up.railway.app/webhooks/retell
RETELL_WEBHOOK_URL=https://your-railway-domain/webhooks/retell

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@tradereceptionist.com

# ── Google Calendar (OAuth 2.0 — per-client user authorisation) ───────────────
# Create a project in Google Cloud Console, enable Calendar API,
# create OAuth 2.0 credentials (type: Web Application).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the Authorised redirect URI in Google Cloud Console exactly, e.g.:
# https://trade-receptionist-production.up.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=https://your-railway-domain/auth/google/callback
# Where to redirect the user after a successful Google Calendar connection:
GOOGLE_OAUTH_SUCCESS_URL=https://tradereceptionist.com/settings

# ── Sentry (build-time source-map upload — Railway build env only) ───────────
# org=trade-receptionist  project=javascript-react  (hardcoded in vite.config.ts)
# Generate token: sentry.io → Settings → Auth Tokens → Create Token
# Required scopes: project:releases, org:read, project:write
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here
