# ── Frontend (Vite — must be prefixed VITE_ to be exposed to the browser) ────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Crisp live chat widget ─────────────────────────────────────────────────────
# Sign up free at https://crisp.chat → add a website → copy the Website ID.
# Set colour to #FF6B2B in Crisp → Settings → Chatbox → Colors.
# Leave blank to disable the widget locally.
VITE_CRISP_WEBSITE_ID=

# ── Sentry DSN is hardcoded in index.tsx (EU region). No env var needed.
# If you want to override it at build time, add VITE_SENTRY_DSN here.

# ── Backend (Railway) ────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:3000,https://tradereceptionist.com

# ── Supabase (server-side only — service-role key bypasses RLS) ───────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Retell AI ─────────────────────────────────────────────────────────────────
# Webhooks are verified using RETELL_API_KEY as the HMAC secret (no separate webhook secret).
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Full public URL that Retell will POST call events to (set in Retell dashboard):
RETELL_WEBHOOK_URL=https://trade-receptionist-production.up.railway.app/webhooks/retell
# Optional canonical public backend base. If set, Google OAuth and Retell custom tools prefer this.
PUBLIC_API_BASE_URL=https://trade-receptionist-production.up.railway.app
# Optional explicit base URL for Retell custom tools. If omitted, the backend derives it from RETELL_WEBHOOK_URL.
RETELL_FUNCTION_BASE_URL=https://trade-receptionist-production.up.railway.app
# Termination URI of the Twilio Elastic SIP Trunk, used when importing a number into
# Retell (outbound dialling + agent binding). This is the trunk's domain, NOT a full URL.
RETELL_SIP_TERMINATION_URI=trade-receptionist-production.pstn.twilio.com

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# SID of the Elastic SIP Trunk that newly-provisioned numbers are attached to so
# inbound calls route into Retell. Without this, bought numbers don't answer.
TWILIO_SIP_TRUNK_SID=TKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Stripe webhook signing secret — get from dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@tradereceptionist.co.uk

# ── Google Calendar (OAuth 2.0 — per-client user authorisation) ───────────────
# Create a project in Google Cloud Console, enable Calendar API,
# create OAuth 2.0 credentials (type: Web Application).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional explicit redirect URI override. If omitted, the backend derives it from PUBLIC_API_BASE_URL
# or RETELL_WEBHOOK_URL so the callback stays on the live backend domain.
GOOGLE_REDIRECT_URI=https://trade-receptionist-production.up.railway.app/auth/google/callback
# Where to redirect the user after a successful Google Calendar connection:
GOOGLE_OAUTH_SUCCESS_URL=https://tradereceptionist.com/settings

# ── Sentry (backend error + performance tracking — Railway runtime env) ──────
# The server only initialises Sentry when SENTRY_DSN is set (see
# server/src/instrument.ts). Leave unset locally; set on Railway to activate
# backend error capture. Get the DSN from sentry.io → your backend project →
# Settings → Client Keys (DSN). The frontend DSN is hardcoded in index.tsx.
SENTRY_DSN=https://your-backend-dsn@oXXXX.ingest.de.sentry.io/XXXX

# ── Sentry (build-time source-map upload — Railway/Vercel build env only) ────
# org=trade-receptionist  project=javascript-react  (hardcoded in vite.config.ts)
# Generate token: sentry.io → Settings → Auth Tokens → Create Token
# Required scopes: project:releases, org:read, project:write
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# ── Notion (internal ops dashboard — server-side only) ────────────────────────
# 1. Create an integration at notion.so/my-integrations (read + insert content)
# 2. Create the three databases, then share each with your integration
# 3. Copy the 32-char database ID from each database URL
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CALL_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SUBSCRIBERS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_INCIDENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Call Log database properties:
#   Caller Name    — Title
#   Phone (last 4) — Text
#   Postcode       — Text
#   Job Type       — Text
#   Outcome        — Select  (booked | lead_captured | enquiry | spam | voicemail | transferred | emergency | no_answer)
#   Urgency        — Select  (routine | urgent | emergency)
#   Duration       — Number
#   Subscriber     — Text
#   Timestamp      — Date
#   Recording      — URL
#
# Subscribers database properties:
#   Business Name  — Title
#   Email          — Email
#   Plan           — Select  (starter | pro | agency)
#   Signup Date    — Date
#
# Incidents database properties:
#   Error Type     — Title
#   Subscriber     — Text
#   Severity       — Select  (low | medium | high | critical)
#   Detail         — Text
#   Timestamp      — Date
