# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Retell AI ─────────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret-here

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@tradereceptionist.com

# ── Google Calendar ───────────────────────────────────────────────────────────
# Minify your service account JSON to a single line before pasting here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}

# ── ElevenLabs (optional voice cloning) ──────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:3000,https://tradereceptionist.com
EMERGENCY_PHONE=999 or 105 for gas emergencies

# ── Gemini (frontend AI demo — used by Vite, not the server) ─────────────────
GEMINI_API_KEY=your-gemini-api-key-here
